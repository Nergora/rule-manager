    </PackageReference>

  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\RuleEngine.Core\RuleEngine.Core.csproj" />

    <ProjectReference Include="..\..\..\src\CampaignEngine.Core\CampaignEngine.Core.csproj" />

  </ItemGroup>

</Project>
